  "item": [
    {
      "name": "1. Hämta alla recept",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ]
      }
    },
    {
      "name": "2. Skapa recept - Pannkakor (Easy)",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Pannkakor\",\n  \"description\": \"Klassiska svenska pannkakor\",\n  \"prepTimeMinutes\": 10,\n  \"cookTimeMinutes\": 20,\n  \"servings\": 4,\n  \"difficulty\": \"Easy\",\n  \"ingredients\": [\n    { \"name\": \"Mjöl\",  \"quantity\": 3,   \"unit\": \"dl\"  },\n    { \"name\": \"Mjölk\", \"quantity\": 6,   \"unit\": \"dl\"  },\n    { \"name\": \"Ägg\",   \"quantity\": 3,   \"unit\": \"st\"  },\n    { \"name\": \"Salt\",  \"quantity\": 0.5, \"unit\": \"tsk\" }\n  ],\n  \"instructions\": [\n    \"Vispa ihop mjöl, mjölk och ägg till en slät smet\",\n    \"Låt vila 30 minuter\",\n    \"Stek i smör i het stekpanna\"\n  ]\n}"
        }
      }
    },
    {
      "name": "3. Skapa recept - Lasagna (Medium)",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}",

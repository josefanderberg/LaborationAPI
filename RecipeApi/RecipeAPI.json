        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Lasagna\",\n  \"description\": \"Klassisk italiensk lasagna med köttfärssås\",\n  \"prepTimeMinutes\": 30,\n  \"cookTimeMinutes\": 45,\n  \"servings\": 6,\n  \"difficulty\": \"Medium\",\n  \"ingredients\": [\n    { \"name\": \"Lasagneplattor\", \"quantity\": 12,  \"unit\": \"st\" },\n    { \"name\": \"Köttfärs\",       \"quantity\": 500, \"unit\": \"g\"  },\n    { \"name\": \"Tomatsås\",       \"quantity\": 400, \"unit\": \"ml\" },\n    { \"name\": \"Bechamelsås\",    \"quantity\": 500, \"unit\": \"ml\" },\n    { \"name\": \"Riven ost\",      \"quantity\": 200, \"unit\": \"g\"  }\n  ],\n  \"instructions\": [\n    \"Bryn köttfärsen i en stekpanna\",\n    \"Blanda med tomatsåsen och låt puttra 15 minuter\",\n    \"Varva lasagneplattor, köttfärssås och bechamelsås\",\n    \"Toppa med riven ost\",\n    \"Grädda i 200°C i 40-45 minuter\"\n  ]\n}"
        }
      }
    },
    {

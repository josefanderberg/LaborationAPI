          "mode": "raw",
          "raw": "{\n  \"name\": \"Boeuf Bourguignon\",\n  \"description\": \"Klassisk fransk köttgryta med rödvin\",\n  \"prepTimeMinutes\": 45,\n  \"cookTimeMinutes\": 180,\n  \"servings\": 6,\n  \"difficulty\": \"Hard\",\n  \"ingredients\": [\n    { \"name\": \"Nötkött\",      \"quantity\": 1000, \"unit\": \"g\"  },\n    { \"name\": \"Rödvin\",       \"quantity\": 750,  \"unit\": \"ml\" },\n    { \"name\": \"Bacon\",        \"quantity\": 200,  \"unit\": \"g\"  },\n    { \"name\": \"Champinjoner\", \"quantity\": 300,  \"unit\": \"g\"  },\n    { \"name\": \"Morötter\",     \"quantity\": 3,    \"unit\": \"st\" },\n    { \"name\": \"Lök\",          \"quantity\": 2,    \"unit\": \"st\" }\n  ],\n  \"instructions\": [\n    \"Marinera köttet i rödvin över natten\",\n    \"Bryn bacon och kött i omgångar\",\n    \"Tillsätt grönsaker och vin\",\n    \"Låt puttra på låg värme i 3 timmar\"\n  ]\n}"
        }
